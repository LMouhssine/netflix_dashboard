# ─────────────────────────────────────────────
#  Netflix Dashboard — variables d'environnement
#  Renommer ce fichier en .env avant de lancer
# ─────────────────────────────────────────────

# Clé secrète Django (générer une valeur aléatoire en prod)
SECRET_KEY=django-insecure-changez-moi-en-production-utilisez-une-vraie-cle

# Mode debug (True = dev, False = prod)
DEBUG=True

# Hôtes autorisés (séparés par virgules, * = tous)
ALLOWED_HOSTS=localhost,127.0.0.1

# Chemin du dataset CSV (optionnel)
# NETFLIX_CSV_PATH=./data/netflix_titles.csv

# Sécurité (recommandé en production)
# SECURE_SSL_REDIRECT=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True
# SECURE_HSTS_SECONDS=31536000
# SECURE_HSTS_INCLUDE_SUBDOMAINS=True
# SECURE_HSTS_PRELOAD=True
